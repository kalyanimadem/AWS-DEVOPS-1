{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AccessOnlyBucketB",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::bucket-b-unique-name"
    },
    {
      "Sid": "ObjectAccessBucketB",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::bucket-b-unique-name/*"
    }
  ]
}
